# Marketing-App Environment-Variablen.
#
# Lokale Entwicklung: Root-.env.local anlegen (alle Apps teilen sie via Symlink).
# Docs: ../../docs/environment-setup.md

# ── Supabase ─────────────────────────────────────────────────────────────────
# Eine Supabase-Instanz pro Umgebung, geteilt von allen Apps.
# Trennung erfolgt intern über RLS, Rollen und Tabellen-Struktur.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # NUR serverseitig, nie NEXT_PUBLIC_!

# ── App-URLs ─────────────────────────────────────────────────────────────────
# Werden für Cross-App-Navigation und absolute Links in versendeten Mails
# verwendet (z. B. Newsletter-Double-Opt-In-Bestätigungslink).
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_COMPANY_URL=http://localhost:3001
NEXT_PUBLIC_CUSTOMER_URL=http://localhost:3002

# ── Umgebung ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENV=development

# ── Email / Leads (Resend) ───────────────────────────────────────────────────
# Account anlegen auf https://resend.com, Domain neuravolt.de verifizieren (SPF/DKIM).
# Ohne RESEND_API_KEY werden Leads in der DB gespeichert, es werden aber keine
# Mails versendet — der Server loggt dann einen Email-Fehler und antwortet
# trotzdem mit ok, damit der Kunde die Store-Failure nicht sieht.
RESEND_API_KEY=re_...
EMAIL_FROM_NAME=NeuraVolt
EMAIL_FROM_ADDRESS=no-reply@neuravolt.de
EMAIL_REPLY_TO=info@neuravolt.de
LEADS_EMAIL_TO=info@neuravolt.de                  # Wohin Team-Benachrichtigungen gehen

# Pepper für IP-Hash (Pseudonymisierung für Spam-Monitoring).
# Zufälliger 32+ Byte String, z. B. erzeugt mit: openssl rand -hex 32
IP_HASH_SALT=change-me-to-random-string

# ── Cloudflare Turnstile (Bot-Schutz für alle Marketing-Forms) ───────────────
# Account: https://dash.cloudflare.com/?to=/:account/turnstile
# Site Key ist public (NEXT_PUBLIC_), Secret nur serverseitig.
# Ohne Secret läuft die Verifikation in Dev mit einer Warning durch, in
# Production schlägt sie hart fehl.
# Cloudflare bietet Test-Keys, die immer passen — siehe:
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ── Sentry (optional) ────────────────────────────────────────────────────────
# Build-Plugin-Token für Source-Map-Upload — in .env.sentry-build-plugin.
# Zur Laufzeit sind die DSNs in sentry.*.config.ts hardcoded.
