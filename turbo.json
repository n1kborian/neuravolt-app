{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env.production", ".env.local"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "NEXT_PUBLIC_MARKETING_URL",
        "NEXT_PUBLIC_COMPANY_URL",
        "NEXT_PUBLIC_CUSTOMER_URL",
        "NEXT_PUBLIC_ENV",
        "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
        "TURNSTILE_SECRET_KEY",
        "RESEND_API_KEY",
        "EMAIL_FROM_NAME",
        "EMAIL_FROM_ADDRESS",
        "EMAIL_REPLY_TO",
        "LEADS_EMAIL_TO",
        "IP_HASH_SALT",
        "STRAPI_API_URL",
        "STRAPI_API_TOKEN",
        "SENTRY_AUTH_TOKEN",
        "NODE_ENV"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "NEXT_PUBLIC_MARKETING_URL",
        "NEXT_PUBLIC_COMPANY_URL",
        "NEXT_PUBLIC_CUSTOMER_URL",
        "NEXT_PUBLIC_ENV",
        "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
        "TURNSTILE_SECRET_KEY",
        "RESEND_API_KEY",
        "EMAIL_FROM_NAME",
        "EMAIL_FROM_ADDRESS",
        "EMAIL_REPLY_TO",
        "LEADS_EMAIL_TO",
        "IP_HASH_SALT",
        "STRAPI_API_URL",
        "STRAPI_API_TOKEN",
        "NODE_ENV"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "clean": {
      "cache": false
    }
  }
}
